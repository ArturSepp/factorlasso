# ─── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Packaging / build artefacts ────────────────────────────────
*.egg-info/
*.egg
.eggs/
build/
dist/
wheels/
pip-wheel-metadata/
MANIFEST

# ─── Testing / coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# ─── Type checkers / linters ────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# ─── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── IDE / editor metadata ──────────────────────────────────────
# JetBrains (PyCharm, IntelliJ, etc.) — note: just `.idea/`, not `*.idea/`
.idea/
# VS Code
.vscode/
# Emacs, Vim, Sublime, nano
*~
*.swp
*.swo
.netrwhist
.\#*
\#*\#

# ─── OS cruft ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Jupyter ────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Local data / secrets ───────────────────────────────────────
.env
.env.local
*.local

# ─── papers/jss_2026/ artefacts ─────────────────────────────────
# Simulation harness outputs (parquet + manifest); regenerable via
# `python -m papers.jss_2026.simulations.run`.
papers/jss_2026/simulations/results/

# §6 application data and outputs.
# Bloomberg holdings are licensed and must not be redistributed;
# the fetcher scripts encode the regeneration recipe.
papers/jss_2026/applications/data/
papers/jss_2026/applications/results/

# LaTeX build artefacts
papers/jss_2026/paper/*.aux
papers/jss_2026/paper/*.bbl
papers/jss_2026/paper/*.blg
papers/jss_2026/paper/*.log
papers/jss_2026/paper/*.out
papers/jss_2026/paper/*.toc
