# ─── papers/jss_2026/ — regenerable artefacts only ──────────────
# The paper source, reproduction scripts, embedded figures, and the
# committed reproduction data inputs (etf_excess_logreturns.csv,
# futures_risk_factors.csv, riskfree_monthly.csv, etf_universe.csv)
# ARE tracked. Only regenerable outputs and build artefacts are ignored.

# Simulation-harness outputs (parquet/csv); regenerated via
# `python -m papers.jss_2026.simulations.run` and the study scripts.
papers/jss_2026/simulations/results/
papers/jss_2026/simulations/results_calibrated/

# The replication bundle is a build output of make_replication_zip.py.
papers/jss_2026/factorlasso_jss_replication.zip

# LaTeX build artefacts (keep article.tex, refs.bib, *.cls, *.bst,
# jsslogo.jpg, and the committed article.pdf).
papers/jss_2026/paper/*.aux
papers/jss_2026/paper/*.bbl
papers/jss_2026/paper/*.blg
papers/jss_2026/paper/*.log
papers/jss_2026/paper/*.out
papers/jss_2026/paper/*.toc
papers/jss_2026/paper/*.synctex.gz

# Local backup dirs
factorlasso-backup/
