# EditorConfig — editor-agnostic enforcement of file conventions.
# Every editor that supports EditorConfig (PyCharm, VS Code, vim, etc.)
# reads this and applies the rules on save. This is what stops Windows
# line-ending flips and missing-trailing-newline issues from recurring.
#
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 120

[*.{yaml,yml,toml,json}]
indent_size = 2

[Makefile]
indent_style = tab
